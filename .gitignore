Thumbs.db

# ── Local secrets / overrides ─────────────────────────────────────────────
*.local.bat
*.local.sh
.env
.env.*
!.env.example
local.properties
secrets.properties

# ── Generated build outputs that live inside src/ ─────────────────────────
# The jexsuite.dependencies-yml convention writes dependencies.yml files
# into src/main/resources/dependency/ on every build. They're derived
# from buildSrc/src/main/kotlin/RuntimeDependencies.kt — that's the
# source of truth. Keeping them out of git avoids merge conflicts on
# every dependency bump.
**/src/main/resources/dependency/dependencies.yml
**/src/main/resources/dependency/paper/dependencies.yml
**/src/main/resources/dependency/spigot/dependencies.yml
